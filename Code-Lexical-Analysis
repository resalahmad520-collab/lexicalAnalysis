#include <iostream>
#include <sstream>
#include <cctype>
using namespace std;

int main()
{
    string code;
    cout << "Enter code: ";
    getline(cin, code);

    string token;
    stringstream ss(code);

    while (ss >> token)
    {
        // Keywords
        if (token == "int" || token == "float" || token == "char" ||
            token == "double" || token == "string" ||
            token == "if" || token == "else" ||
            token == "for" || token == "while" || token == "return")
        {
            cout << token << " : Keyword" << endl;
        }

        // Operators
        else if (token == "+" || token == "-" || token == "*" ||
                 token == "/" || token == "=" || token == "==" ||
                 token == "!=" || token == "<" || token == ">" ||
                 token == "<=" || token == ">=")
        {
            cout << token << " : Operator" << endl;
        }

        // Separators
        else if (token == ";" || token == "," ||
                 token == "(" || token == ")" ||
                 token == "{" || token == "}")
        {
            cout << token << " : Separator" << endl;
        }

        // Numbers
        else if (isdigit(token[0]))
        {
            cout << token << " : Number" << endl;
        }

        // Identifiers
        else if (isalpha(token[0]) || token[0] == '_')
        {
            cout << token << " : Identifier" << endl;
        }

        // Invalid Token
        else
        {
            cout << token << " : Invalid Token" << endl;
        }
    }

    return 0;
}
